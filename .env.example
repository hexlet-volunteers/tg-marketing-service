# Сконфигурируйте проект: подставьте свои значения после "=".
# Скопируйте этот файл в ".env" и заполните значения.
# Убедитесь, что ".env" в .gitignore — не допускайте выгрузки секретов на github.


# Django core
# Секретный ключ Django.
SECRET_KEY=your_secret_key_here

# Переменная DEBUG только для разработки.
# В остальных случаях ее необходимо оставить в комментарии
# Допустимые значения (регистр не важен, указывать без ""): "1", "true", "yes", "y", "on"
DEBUG=True

# Переключатель "продакшн"-режима: используется для выбора БД и redirect_uri для Yandex OAuth.
# "t" — Прод (Postgres), любое другое значение/пусто — разработка (SQLite).
PROD=f


# База данных

# SQLite (если PROD != "t")
DATABASE_URL=sqlite:///db.sqlite3

# Postgres (если PROD=t)
NAMEDB=your_db_name
USERDB=your_db_user
PASSWORDDB=your_db_password
HOSTDB=localhost
PORTDB=5432


# Telegram API (для парсера)
# Авторизуйтесь на https://my.telegram.org/apps по номеру телефона вашего Telegram-аккаунта.
# Откройте API development tools, заполните поля App configuration (если уже заполнены — не меняйте) и сохраните настройки.
# Заполните данные о приложении и нажмите "Create application"
# Полученные API ID и API HASH, копируем в TELEGRAM_API_ID и TELEGRAM_API_HASH
TELEGRAM_API_ID=your_tg_api_id
TELEGRAM_API_HASH=your_tg_api_hash

# Строка сессии, чтобы не логиниться заново при каждом запуске.
# Сгенерируйте / обновите строку сессии с помощью "make s". Новая строка сессии появится в конце .env.
#TELEGRAM_SESSION_STRING=

# Данные аккаунта, от имени которого работает парсер.
PHONE=80000000000
TELEGRAM_PASSWORD=your_tg_password


# Yandex OAuth
# Создайте приложение на https://oauth.yandex.ru/ ("Для авторизации пользователей").
# Укажите Redirect URI, соответствующий вашему окружению:
# - dev: https://localhost:8000/accounts/yandex/login/callback/
# - prod: https://hexlet-price-tracker-8znh.onrender.com/accounts/yandex/login/callback/
# Включите все права доступа:
# - Доступ к адресу электронной почты
# - Доступ к логину, имени и фамилии, полу
# - Доступ к портрету пользователя
# Заполните поля полученными данными
CLIENT_ID_YA=your_yandex_client_id
SECRET_ID_YA=your_yandex_client_secret


# AI settings
# Получить API-ключ можно на https://console.anthropic.com/
# Модель Claude в формате "claude-*"
# Включить/выключить AI (AI_ENABLED=True/False)
# Таймаут запроса к API в секундах
# Максимальное количество токенов в ответе по умолчанию 1024
AI_API_KEY=your_ai_api_key
AI_MODEL=claude-sonnet-5
AI_ENABLED=True
AI_TIMEOUT_SECONDS=30
AI_MAX_TOKENS=1024